# ============================================================
# Пример переменных окружения для Telegram Бота-Напоминалки
# Скопируйте этот файл в .env и заполните своими данными:
#   cp .env.example .env
# ============================================================

# --- Telegram Bot ---
# Токен бота, полученный у @BotFather в Telegram
BOT_TOKEN=1234567890:AABBccDDeeFFggHHiiJJkkLLmmNNoo-EXAMPLE

# --- База данных ---
# Путь к файлу SQLite (создастся автоматически при первом запуске)
DATABASE_PATH=data/reminders.db

# --- Часовой пояс ---
# Используется для корректного отображения и планирования напоминаний
# Список зон: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=Europe/Moscow

# --- Логирование ---
# Уровень логов: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# --- APScheduler ---
# Интервал проверки напоминаний в секундах (по умолчанию 60)
SCHEDULER_INTERVAL=60
